# =============================================================================
# Environment variables reference (Amplify / local)
# Copy to .env.local for local dev; set in Amplify Console for deployment.
# =============================================================================

# -----------------------------------------------------------------------------
# Google OAuth (required for Calendar auth)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production: https://<your-amplify-domain>/api/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# -----------------------------------------------------------------------------
# AI / LLM (optional – only if using assignment decompose or AI features)
# -----------------------------------------------------------------------------
# Option A: OpenAI
OPENAI_API_KEY=

# Option B: Ollama (self‑hosted or remote)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
